# Copy this file to android/keystore/keystore.properties and fill in real values.
# NEVER commit keystore.properties — it is in .gitignore.
#
# Generate the keystore once with:
#   keytool -genkey -v \
#     -keystore android/keystore/farmcalcy-release.keystore \
#     -alias farmcalcy-release \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -dname "CN=FarmCalcy, OU=PCFMS, O=FarmCalcy Pvt Ltd, L=Hyderabad, S=Telangana, C=IN"
#
# Store the generated .keystore file and this filled properties file in a
# password manager or secrets vault — losing them means you can never update
# the app on the Play Store.

MYAPP_RELEASE_STORE_FILE=../keystore/farmcalcy-release.keystore
MYAPP_RELEASE_KEY_ALIAS=farmcalcy-release
MYAPP_RELEASE_STORE_PASSWORD=REPLACE_WITH_STORE_PASSWORD
MYAPP_RELEASE_KEY_PASSWORD=REPLACE_WITH_KEY_PASSWORD
